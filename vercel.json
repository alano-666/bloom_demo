{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "buildCommand": "npm run build --workspace @bloom/shared && npm run build --workspace @bloom/api",
  "installCommand": "npm install",
  "env": {
    "ALIBABA_BAILIAN_API_KEY": "@alibaba-bailian-api-key",
    "ZAI_API_KEY": "@zai-api-key"
  }
}
