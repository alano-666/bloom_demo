{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "buildCommand": "npm run build --workspace @bloom/shared && npm run build --workspace @bloom/api",
  "installCommand": "npm install",
  "outputDirectory": "api",
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
