# Bloom 环境变量模板
# 复制为 .env.local 用于本地 API；线上请在 Vercel Project Settings → Environment Variables 中配置。

# Supabase（生产环境必须配置，否则仅使用进程内存，实例重启后数据会丢失）
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 允许访问 API 的前端来源，多个来源用逗号分隔
CORS_ORIGINS=https://alano-666.github.io

# AI Provider（可选；未配置时使用规则 fallback）
ALIBABA_BAILIAN_API_KEY=
ALIBABA_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_BAILIAN_MODEL=qwen-plus

# 或使用智谱
ZAI_API_KEY=
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_MODEL=glm-4.5
